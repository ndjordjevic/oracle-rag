# Copy to .env and fill in your values.

# --- LLM (required for generation) ---
# Provider: openai | anthropic (default: anthropic)
# ORACLE_RAG_LLM_PROVIDER=anthropic
# Model name (provider-specific). If unset: openai=gpt-4o-mini, anthropic=claude-haiku-4-5
# ORACLE_RAG_LLM_MODEL=claude-haiku-4-5

# OpenAI (required when ORACLE_RAG_LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (required when ORACLE_RAG_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Embeddings (required for indexing and retrieval) ---
# Provider: openai (default) | cohere
# ORACLE_RAG_EMBEDDING_PROVIDER=openai
# Model name. If unset: openai=text-embedding-3-small, cohere=embed-english-v3.0
# ORACLE_RAG_EMBEDDING_MODEL=text-embedding-3-small

# Cohere (required when ORACLE_RAG_EMBEDDING_PROVIDER=cohere; pip install oracle-rag[cohere])
# COHERE_API_KEY=your_cohere_api_key_here

# --- Evaluator (LLM-as-judge for evaluation runs) ---
# Provider: openai (default) | anthropic
# ORACLE_RAG_EVALUATOR_PROVIDER=openai
# Model for correctness/relevance. If unset: openai=gpt-4o, anthropic=claude-sonnet-4-6
# ORACLE_RAG_EVALUATOR_MODEL=gpt-4o
# Model for groundedness/retrieval_relevance (context-heavy). If unset: openai=gpt-4o-mini, anthropic=claude-haiku-4-5
# ORACLE_RAG_EVALUATOR_MODEL_CONTEXT=gpt-4o-mini

# --- Chroma vector store ---
# Persist directory (default: chroma_db, project-local)
# ORACLE_RAG_PERSIST_DIR=chroma_db
# Collection name (default: oracle_rag)
# ORACLE_RAG_COLLECTION_NAME=oracle_rag

# --- Chunking ---
# Chunk size in characters (default: 1000)
# ORACLE_RAG_CHUNK_SIZE=1000
# Chunk overlap in characters (default: 200)
# ORACLE_RAG_CHUNK_OVERLAP=200
# Enable structure-aware chunking heuristics for code/table boundaries (default: true)
# ORACLE_RAG_STRUCTURE_AWARE_CHUNKING=true

# --- Parent-child retrieval ---
# Embed small chunks for precise matching, return larger parent chunks for context (default: false)
# ORACLE_RAG_USE_PARENT_CHILD=false
# Parent chunk size in characters (default: 2000)
# ORACLE_RAG_PARENT_CHUNK_SIZE=2000
# Child chunk size in characters (default: 400)
# ORACLE_RAG_CHILD_CHUNK_SIZE=400

# --- Retrieval ---
# Number of chunks to retrieve (default: 20)
# ORACLE_RAG_RETRIEVE_K=20

# --- Re-ranking (Cohere; requires oracle-rag[cohere] and COHERE_API_KEY) ---
# Enable Cohere re-ranking (default: false)
# ORACLE_RAG_USE_RERANK=false
# Chunks to fetch before reranking (default: same as ORACLE_RAG_RETRIEVE_K)
# ORACLE_RAG_RERANK_RETRIEVE_K=20
# Chunks to return after reranking (default: 10)
# ORACLE_RAG_RERANK_TOP_N=10

# --- Multi-query retrieval ---
# Generate query variants via LLM, merge results (default: false)
# ORACLE_RAG_USE_MULTI_QUERY=false
# Number of alternative queries (default: 4)
# ORACLE_RAG_MULTI_QUERY_COUNT=4

# --- RAG answer style ---
# thorough (default) | concise. Used by evaluation target and MCP query default.
# ORACLE_RAG_RESPONSE_STYLE=thorough

# --- Optional: LangSmith tracing (see notes/langsmith-setup.md) ---
# LANGSMITH_API_KEY=your_langsmith_api_key_here
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=oracle-rag
