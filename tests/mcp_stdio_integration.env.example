# Copy to tests/.mcp_stdio_integration.env and fill in (file is gitignored).
# Or export the variables in your shell / CI secrets — env wins over this file.
#
# CI (e.g. GitHub Actions): set repository secrets OPENAI_API_KEY and ANTHROPIC_API_KEY;
# do not commit real keys.
#
# Optional: set PINRAG_MCP_ITEST_ENV_FILE to an absolute path to use a different file.
#
# PyPI stdio integration test (tests/test_mcp_stdio_pypi.py):
#   PINRAG_MCP_ITEST_SKIP_PYPI=1     — skip that test (no PyPI download).
#   PINRAG_MCP_ITEST_PYPI_SPEC=pinrag==0.9.0  — pin version (default: pinrag = latest).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
